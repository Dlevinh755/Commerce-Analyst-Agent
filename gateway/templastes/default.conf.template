server {
    listen ${GATEWAY_PORT};
    server_name ${DOMAIN_NAME};

    set $cors_origin "";
    if ($http_origin ~* ^http://(localhost|127\.0\.0\.1):(5173|5174|5175)$) {
        set $cors_origin $http_origin;
    }

    add_header Access-Control-Allow-Origin $cors_origin always;
    add_header Access-Control-Allow-Credentials "true" always;
    add_header Access-Control-Allow-Headers "Authorization,Content-Type,Accept,Origin,X-Requested-With" always;
    add_header Access-Control-Allow-Methods "GET,POST,PUT,PATCH,DELETE,OPTIONS" always;
    add_header Vary "Origin" always;

    if ($request_method = OPTIONS) {
        return 204;
    }

    # Resolve Docker service DNS at runtime so gateway can start even if a backend is down.
    resolver 127.0.0.11 ipv6=off valid=30s;

    # Tối ưu hóa log cho Docker
    access_log /dev/stdout;
    error_log /dev/stderr;

    # Cấu hình Proxy Header chung
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;

    # Điều hướng Auth Service (FastAPI)
    # Client gọi: /api/v1/auth/register → auth-service nhận: /auth/register
    location /api/v1/auth/ {
        set $auth_upstream http://${AUTH_SERVICE_HOST}:${AUTH_SERVICE_PORT};
        rewrite ^/api/v1/auth/(.*)$ /auth/$1 break;
        proxy_pass $auth_upstream;
    }

    # Điều hướng Product Service (FastAPI)
    # Client gọi: /api/v1/products/... → product-service nhận: /...
    location /api/v1/products/ {
        set $product_upstream http://${PRODUCT_SERVICE_HOST}:${PRODUCT_SERVICE_PORT};
        rewrite ^/api/v1/products/(.*)$ /$1 break;
        proxy_pass $product_upstream;
    }

    # Điều hướng Cart Service (FastAPI)
    # Client gọi: /api/v1/cart/... → cart-service nhận: /cart/...
    location /api/v1/cart {
        set $cart_upstream http://${CART_SERVICE_HOST}:${CART_SERVICE_PORT};
        rewrite ^/api/v1/cart$ /cart break;
        rewrite ^/api/v1/cart/(.*)$ /cart/$1 break;
        proxy_pass $cart_upstream;
    }

    # Điều hướng Order Service (FastAPI)
    # Client gọi: /api/v1/orders/... → order-service nhận: /orders/...
    location /api/v1/orders {
        set $order_upstream http://${ORDER_SERVICE_HOST}:${ORDER_SERVICE_PORT};
        rewrite ^/api/v1/orders$ /orders break;
        rewrite ^/api/v1/orders/(.*)$ /orders/$1 break;
        proxy_pass $order_upstream;
    }

    # Điều hướng Payment Service (FastAPI)
    # Client gọi: /api/v1/payments/... → payment-service nhận: /payments/...
    location /api/v1/payments {
        set $payment_upstream http://${PAYMENT_SERVICE_HOST}:${PAYMENT_SERVICE_PORT};
        rewrite ^/api/v1/payments$ /payments break;
        rewrite ^/api/v1/payments/(.*)$ /payments/$1 break;
        proxy_pass $payment_upstream;
    }

    # Điều hướng VNPay Service (Django)
    # Client gọi: /api/v1/vnpay/... → vnpay-service nhận: /api/...
    location /api/v1/vnpay/ {
        set $vnpay_upstream http://${VNPAY_SERVICE_HOST}:${VNPAY_SERVICE_PORT};
        rewrite ^/api/v1/vnpay/(.*)$ /api/$1 break;
        proxy_pass $vnpay_upstream;
    }

    # Điều hướng Kafka UI (Công cụ quản lý)
    location /kafka-ui/ {
        set $kafka_ui_upstream http://${KAFKA_UI_HOST}:${KAFKA_UI_PORT};
        rewrite ^/kafka-ui/(.*)$ /$1 break;
        proxy_pass $kafka_ui_upstream;
    }

    # Trang kiểm tra trạng thái Gateway
    location /health {
        return 200 'Gateway is up and running';
    }
}